  <script>
    // --- ≥ołŐęOĮdßA≠ž•Ľ©“¶≥™ļłÍģ∆Ķ≤ļc (PERIODS, MOCK_SCHEDULE Ķ•) ---
    const PERIODS = [
      { label:'1', start:[8,10]  }, { label:'2', start:[9,10]  },
      { label:'3', start:[10,10] }, { label:'4', start:[11,10] },
      { label:'5', start:[13,5]  }, { label:'6', start:[14,5]  },
      { label:'7', start:[15,10] },
    ];
    const PERIOD_DURATIONS = [ [50,80,100],[50,80,100],[50,80,100],[50], [50,80,100],[50,80,100],[50] ];
    const MOCK_SCHEDULE = {
      day1: [
        { subject:'įÍ°@§Ś', start:[8,20], duration:100 },
        { subject:'≠^°@§Ś', start:[10,20], duration:100 },
        { subject:'ĪM∑~¨ž•ō°]§@°^', start:[13,10], duration:100 },
      ],
      day2: [
        { subject:'ľ∆°@ĺ«', start:[8,20], duration:80 },
        { subject:'ĪM∑~¨ž•ō°]§G°^', start:[10,20], duration:100 },
      ],
    };
    const WEEKDAYS = ['§ť','§@','§G','§T','•|','§≠','§Ľ'], DAYS_EN = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

    let currentMode = 'monthly', examOn = false, selectedPeriod = null, selectedDuration = 50, mockOn = false, mockDay = 'day1';

    // --- ≥∑™Šį Ķe ---
    function createSnow() {
      const container = document.getElementById('snow-container');
      for (let i = 0; i < 50; i++) {
        const snow = document.createElement('div');
        snow.className = 'snow-particle';
        const size = Math.random() * 5 + 2;
        snow.style.width = `${size}px`;
        snow.style.height = `${size}px`;
        snow.style.left = `${Math.random() * 100}%`;
        snow.style.top = `${Math.random() * 100}%`;
        snow.style.animation = `fall ${Math.random() * 10 + 5}s linear infinite`;
        snow.style.opacity = Math.random();
        container.appendChild(snow);
      }
    }

    // CSS į Ķe™`§J
    const style = document.createElement('style');
    style.innerHTML = `
      @keyframes fall {
        0% { transform: translateY(-10vh) translateX(0); }
        100% { transform: translateY(110vh) translateX(20px); }
      }
    `;
    document.head.appendChild(style);
    createSnow();

    // --- ģ÷§ŖŇřŅŤ (¨Mģg¶‹∑s UI) ---
    function pad(n){ return String(n).padStart(2,'0'); }

    // ľ“¶°§Ńīęľň¶°ņu§∆
    function setMode(mode) {
      currentMode = mode;
      const isMon = mode === 'monthly';
      document.getElementById('btnMonthly').className = isMon ? 'px-8 py-2 rounded-full font-headline font-bold text-sm bg-primary text-white' : 'px-8 py-2 rounded-full font-headline font-bold text-sm text-on-surface-variant hover:bg-white/50';
      document.getElementById('btnMock').className = !isMon ? 'px-8 py-2 rounded-full font-headline font-bold text-sm bg-tertiary text-white' : 'px-8 py-2 rounded-full font-headline font-bold text-sm text-on-surface-variant hover:bg-white/50';
      document.getElementById('panelMonthly').classList.toggle('hidden', !isMon);
      document.getElementById('panelMock').classList.toggle('hidden', isMon);
    }
    document.getElementById('btnMonthly').onclick = () => setMode('monthly');
    document.getElementById('btnMock').onclick = () => setMode('mock');

    // ... (¶Ļ≥B¨Ŕ≤§ßA≠ž•Ľ™ļ rebuildDurationBtns, detectPeriod, updateMonthly, updateMock Ķ• JS ®Á¶°)
    // Ĺ–ĪNßA index.html §§ script ľ–Ň“§ļ™ļ°uŇřŅŤ®Á¶°°v™ĹĪĶ∂K¶^≥ołŐ°A•\ĮŗßY∑|ßĻ¨ŁĽőĪĶ°C
    // ™`∑N°G≠ž•Ľ™ļ .style.display = 'none' ßÔ¨į .classList.add('hidden') •H≤Ň¶X∑sľň¶°°C

    /* [•H§U¨į≠žŇřŅŤ≤ĺī”įŌ°AęOęýĽP≠ž™©§@≠P] */
    function tick() {
      const now = new Date();
      const h = pad(now.getHours()), m = pad(now.getMinutes()), s = pad(now.getSeconds());
      document.getElementById('h0').textContent = h[0];
      document.getElementById('h1').textContent = h[1];
      document.getElementById('m0').textContent = m[0];
      document.getElementById('m1').textContent = m[1];
      document.getElementById('s0').textContent = s[0];
      document.getElementById('s1').textContent = s[1];
      document.getElementById('dateLine').textContent = `${now.getFullYear()} °P ${pad(now.getMonth()+1)} °P ${pad(now.getDate())}`;
      document.getElementById('weekday').textContent = `¨PīŃ${WEEKDAYS[now.getDay()]} °P ${DAYS_EN[now.getDay()]}`;
      
      // ßů∑s§Ž¶“/ľ“ņņ¶“ logic
      if(typeof updateMonthly === 'function') updateMonthly(now);
      if(typeof updateMock === 'function') updateMock(now);
    }
    
    setInterval(tick, 1000);
    tick();

    // ≥ołŐ¨į§F¬≤ľš°AßAĽ›≠nĪNßA≠ž©lĶ{¶°ĹX§§™ļ updateMonthly, updateMock, rebuildDurationBtns Ķ•®Á¶°∂K¶^≥ołŐßY•i°C
  </script>
